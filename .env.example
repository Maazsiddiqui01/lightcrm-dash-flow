# === Frontend (Vite) ===
# These have hardcoded fallbacks in client.ts for Lovable compatibility.
# When migrating to Azure, remove fallbacks and rely solely on these env vars.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# === Supabase Edge Function Secrets ===
# Configure these in: Supabase Dashboard > Project Settings > Secrets

# n8n Webhook URLs (used by n8n_proxy edge function)
N8N_WEBHOOK_DRAFT_EMAIL=https://your-n8n.app.n8n.cloud/webhook/Draft-Email
N8N_WEBHOOK_EMAIL_BUILDER=https://your-n8n.app.n8n.cloud/webhook/Email-Builder
N8N_WEBHOOK_AGENT_TASKS=https://your-n8n.app.n8n.cloud/webhook/Agent-Tasks
N8N_WEBHOOK_TODO_CONTACTS=https://your-n8n.app.n8n.cloud/webhook/Get-To-do-Contacts
N8N_WEBHOOK_VOICE_TRANSCRIPTION=https://your-n8n.app.n8n.cloud/webhook/Voice-Transcription
N8N_WEBHOOK_TODO=https://your-n8n.app.n8n.cloud/webhook/Get-To-do
N8N_WEBHOOK_EMAIL_DRAFT=https://your-n8n.app.n8n.cloud/webhook/Email-Draft
N8N_WEBHOOK_SQL_AGENT=https://your-n8n.app.n8n.cloud/webhook/SQL-Agent
N8N_WEBHOOK_OPPORTUNITIES_EMAIL=https://your-n8n.app.n8n.cloud/webhook/Opportunities-Email
N8N_WEBHOOK_GROUP_CONTACT=https://your-n8n.app.n8n.cloud/webhook/Group-Contact

# Existing edge function URLs (post_to_n8n, post_to_n8n_2026)
N8N_WEBHOOK_2026_PIPELINE=https://your-n8n.app.n8n.cloud/webhook/2026-Pipeline

# CORS (comma-separated origins, leave unset for wildcard in Lovable)
# ALLOWED_ORIGINS=https://your-app.lovable.app,https://your-domain.com
